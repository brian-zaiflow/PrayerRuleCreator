# Server Configuration
PORT=5000
NODE_ENV=development

# Document Persistence Feature Flag
# Set to 'true' to enable save/load/delete features (requires DATABASE_URL)
# Set to 'false' for "create and print only" mode (no database needed)
ENABLE_DOCUMENT_PERSISTENCE=false
VITE_ENABLE_DOCUMENT_PERSISTENCE=false

# Database Configuration (only required if ENABLE_DOCUMENT_PERSISTENCE=true)
# For local PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/database_name
# For Neon serverless PostgreSQL:
# DATABASE_URL=postgresql://user:password@host.neon.tech/database_name
DATABASE_URL=
